# ============================================================
# Salin file ini menjadi ".env" (tanpa kata "example") dan
# isi nilainya. JANGAN pernah commit file .env ke GitHub.
# ============================================================

# Dari Supabase Dashboard > Settings > API > Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Dari Supabase Dashboard > Settings > API > service_role key
# (klik Reveal untuk melihatnya — JAGA KERAHASIANNYA!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Teks acak panjang (min 32 karakter) — bebas kamu isi sendiri
# contoh: bisa dari https://www.uuidgenerator.net/
JWT_SECRET=ganti-dengan-teks-acak-yang-sangat-panjang-dan-rahasia

# Kode yang dibagikan ke SEMUA MAHASISWA agar bisa login
CLASS_CODE=MANAJEMEN1A

# Kode khusus untuk dosen/admin (jangan disebar ke mahasiswa!)
ADMIN_CODE=DOSENMNJ2026

# URL frontend setelah di-deploy (misal https://tracker-kelas.vercel.app)
# Gunakan * untuk mengizinkan semua origin saat development
FRONTEND_URL=*

# Port backend (Railway/Render mengisi ini otomatis, jangan diubah)
PORT=3000
